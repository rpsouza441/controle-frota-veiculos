# Exemplo de configuração (.env) para o Docker
# Copie este arquivo para .env e altere os valores para produção.

# DICA: Para gerar senhas seguras ou o JWT_SECRET pelo terminal, você pode usar o Node.js 
# (que já está instalado no seu ambiente) rodando o seguinte comando:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Se preferir usar o OpenSSL (no Linux, Mac ou Git Bash do Windows):
# openssl rand -base64 32

# ---------------------------------------------------------
# Configurações do Banco de Dados MariaDB
# ---------------------------------------------------------
# Nome do banco de dados a ser criado
DB_NAME=fleet_control

# Usuário que a aplicação usará para conectar
DB_USER=app_user

# Senha do usuário da aplicação (gere uma segura)
DB_PASSWORD=sua_senha_segura_do_banco_aqui

# Senha do superusuário root do banco (gere uma muito segura)
DB_ADMIN_PASSWORD=sua_senha_root_do_banco_aqui

# ---------------------------------------------------------
# Configurações da Aplicação
# ---------------------------------------------------------
# Chave secreta para assinar os tokens de login (MUITO IMPORTANTE!)
# Gere uma chave longa e complexa para evitar acessos indevidos.
JWT_SECRET=seu_segredo_jwt_super_seguro_aqui

# Domínio corporativo que a aplicação vai aceitar para novos cadastros
CORPORATE_EMAIL_DOMAIN=@empresa.com.br
